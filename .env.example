# ─────────────────────────────────────────────────────────────
# linkedin-voice-agent — variables de entorno
#
# Copia este archivo como .env y rellena cada valor.
# NUNCA subas .env al repositorio.
# ─────────────────────────────────────────────────────────────

# ── IA ────────────────────────────────────────────────────────
# Obtener en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Telegram ──────────────────────────────────────────────────
# 1. Abre Telegram y busca @BotFather
# 2. Envía /newbot y sigue las instrucciones
# 3. BotFather te dará el token → pégalo aquí
TELEGRAM_BOT_TOKEN=

# Tu ID de chat personal con el bot:
# 1. Envía cualquier mensaje a tu bot
# 2. Visita: https://api.telegram.org/bot<TOKEN>/getUpdates
# 3. Copia el valor de "chat" → "id"
TELEGRAM_CHAT_ID=

# ── LinkedIn OAuth (necesario para ejecutar get_linkedin_token.py) ──
# 1. Ve a https://www.linkedin.com/developers/apps
# 2. Crea una nueva app (o usa una existente)
# 3. En la pestaña "Auth" copia Client ID y Client Secret
# 4. En "OAuth 2.0 settings" añade como Redirect URL: http://localhost:8000/callback
# 5. En "Products" solicita acceso a "Share on LinkedIn" (scope w_member_social)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── LinkedIn Runtime (generadas ejecutando: python get_linkedin_token.py) ──
# Ejecuta get_linkedin_token.py una vez y copia aquí los valores que te muestra.
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_USER_ID=
